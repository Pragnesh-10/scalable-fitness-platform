# Environment Variables for AWS Elastic Beanstalk
# Replace these values with your actual secrets

ENVIRONMENT=production
NODE_ENV=production
PORT=5001
TRUST_PROXY=true

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://your_username:your_password@your-cluster.mongodb.net/fitpulse?appName=fitpulse&retryWrites=true&w=majority

# JWT & Security
JWT_SECRET=your-256-bit-random-secret-key-here-min-32-chars-for-production
JWT_EXPIRES_IN=7d
COACH_REGISTRATION_KEY=your-secret-coach-invite-code
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_MAX_AGE_MS=604800000
# Optional: set when sharing cookies across subdomains (for example .your-domain.com)
# AUTH_COOKIE_DOMAIN=.your-domain.com

# CORS Configuration
FRONTEND_URL=https://your-frontend-domain.com
PROD_FRONTEND_URL=https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Rate Limiting (configured values from security hardening)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTHENTICATED_RATE_LIMIT_MAX=300
AUTHENTICATED_RATE_LIMIT_WINDOW_MS=60000

# OAuth (if using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FITBIT_CLIENT_ID=your-fitbit-client-id
FITBIT_CLIENT_SECRET=your-fitbit-client-secret

# Redis (if needed)
REDIS_URL=redis://localhost:6379
