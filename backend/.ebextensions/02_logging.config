option_settings:
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: "true"
    DeleteOnTerminate: "false"
    RetentionInDays: "30"

commands:
  01_log_dir:
    command: "mkdir -p /var/log/nodejs && chmod 755 /var/log/nodejs"
    ignoreErrors: true

  02_logrotate:
    command: |
      cat > /etc/logrotate.d/nodejs << 'EOF'
      /var/log/nodejs/*.log {
        daily
        missingok
        rotate 14
        compress
        delaycompress
        notifempty
        create 0600 ec2-user ec2-user
        sharedscripts
      }
      EOF
    ignoreErrors: true
